# .env.example for OxFin backend
# Database configuration
POSTGRES_USER=oxfin_user
POSTGRES_PASSWORD=oxfin_pass
POSTGRES_DB=oxfin
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis configuration
REDIS_URL=redis://localhost:6379

# API keys (replace with real values when deploying)
OXFIN_STRIPE_SECRET_KEY=your_stripe_secret_key
OXFIN_RAZORPAY_KEY_ID=your_razorpay_key_id
OXFIN_RAZORPAY_KEY_SECRET=your_razorpay_key_secret
OXFIN_KITE_API_KEY=your_kite_api_key
OXFIN_KITE_ACCESS_TOKEN=your_kite_access_token
OXFIN_GROWW_API_KEY=your_groww_api_key

# Feature toggles
OXFIN_PAYMENT_PROVIDER=stripe
OXFIN_INVESTMENT_PROVIDER=zerodha
